<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <!-- 1. 부모 레이아웃 -->
    <LinearLayout
        android:id="@+id/text_box_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:orientation="vertical">

        <!-- X 버튼 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="0dp"
            android:translationZ="10dp">

            <TextView
                android:id="@+id/btn_close_text_box"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:background="@null"
                android:gravity="center"
                android:text="✕"
                android:textColor="#000000"
                android:textSize="22sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- 2. 텍스트 박스 + TTS 스피커 아이콘 합치기 -->
        <LinearLayout
            android:id="@+id/text_content_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_box_rounded"
            android:elevation="4dp"
            android:minHeight="120dp"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- [수정] 텍스트 내용에 스크롤 기능 추가 -->
            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <TextView
                    android:id="@+id/content_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="20dp"
                    android:paddingTop="20dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="8dp"
                    android:text="내용이 여기에 표시됩니다."
                    android:textColor="#333333"
                    android:textSize="16sp" />
            </androidx.core.widget.NestedScrollView>


            <!-- 하단 버튼 영역 (좌측: 하이라이트 & 글자조절, 우측: TTS) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:paddingBottom="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- 좌측 영역: 하이라이트 버튼과 그 아래 글자 크기 조절 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 상단: 하이라이트 버튼 -->
                    <Button
                        android:id="@+id/btn_highlight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="하이라이트 안내"
                        android:textSize="12sp"
                        android:padding="10dp"
                        android:background="@drawable/bg_recommend_btn"
                        android:visibility="visible"
                        android:layout_marginBottom="8dp"/>

                    <!-- 하단: 글자 크기 조절 영역 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/btn_font_decrease"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="-"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:textColor="#333333"
                            android:background="?android:attr/selectableItemBackground" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="글자 크기"
                            android:textSize="15sp"
                            android:layout_marginHorizontal="4dp"
                            android:textColor="#666666"/>

                        <TextView
                            android:id="@+id/btn_font_increase"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="+"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:textColor="#333333"
                            android:background="?android:attr/selectableItemBackground" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 중앙 여백: TTS 버튼을 오른쪽 끝으로 밀어냄 -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- 우측 끝: TTS 스피커 아이콘 (글자 조절 영역과 높이가 맞음) -->
                <ImageView
                    android:id="@+id/btn_tts_play"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:contentDescription="음성 듣기"
                    android:padding="4dp"
                    android:src="@drawable/ic_speaker" />
            </LinearLayout>
        </LinearLayout>

        <!-- 3. 메뉴 3번용 직접 질문 -->
        <LinearLayout
            android:id="@+id/button_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/btn_ask_question"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_box_rounded"
                android:elevation="4dp"
                android:gravity="center"
                android:padding="20dp"
                android:text="질문 하시겠습니까?"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/btn_view_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_box_rounded"
                android:elevation="4dp"
                android:gravity="center"
                android:padding="20dp"
                android:text="이전 질문을 보겠습니까?"
                android:textColor="#333333" />
        </LinearLayout>

        <!-- 4. 추천 질문 -->
        <LinearLayout
            android:id="@+id/recommend_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/rec_q1"
                style="@style/RecommendButtonStyle"
                android:text="질문 1" />

            <TextView
                android:id="@+id/rec_q2"
                style="@style/RecommendButtonStyle"
                android:text="질문 2" />

            <TextView
                android:id="@+id/rec_q3"
                style="@style/RecommendButtonStyle"
                android:text="질문 3" />

            <TextView
                android:id="@+id/rec_q4"
                style="@style/RecommendButtonStyle"
                android:text="질문 4"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>